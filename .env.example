NODE_ENV=development
PORT=3000
APP_BASE_URL=https://your-render-service.onrender.com

# Slack
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#ops-admin

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google OAuth / API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://<your-render-service>.onrender.com/oauth/google/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Tactiq MCP (OAuth + sync)
TACTIQ_MCP_URL=https://mcp.tactiq.io
TACTIQ_OAUTH_SCOPES=mcp:meetings:own mcp:meetings:details
# Optional if you pre-provision OAuth client credentials:
TACTIQ_CLIENT_ID=
TACTIQ_CLIENT_SECRET=
# Optional explicit callback URL override:
TACTIQ_REDIRECT_URI=https://your-render-service.onrender.com/integrations/tactiq/callback
# Optional token bootstrap (usually saved after /integrations/tactiq/connect flow):
TACTIQ_ACCESS_TOKEN=
TACTIQ_REFRESH_TOKEN=
# Optional scheduled sync job (e.g. every 30 minutes):
TACTIQ_SYNC_CRON=

# Meeting transcript webhook
TRANSCRIPT_WEBHOOK_SECRET=replace_me

# Cron schedule for weekday morning digest
EMAIL_DIGEST_CRON=0 8 * * 1-5
